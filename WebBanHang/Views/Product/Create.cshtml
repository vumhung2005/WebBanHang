@model WebBanHang.Models.Entity.Product

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Create</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <script>
        function editProduct(id, name, price, quantity, categoryId) {
            document.getElementById("Id").value = id;
            document.getElementById("Name").value = name;
            document.getElementById("Price").value = price;
            document.getElementById("Quantity").value = quantity;
            document.getElementById("CategoryId").value = categoryId;

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
    </script>
</head>

<body>
    <div class="container mt-5">

        <h2 class="mb-4 text-center">Thêm / Sửa sản phẩm</h2>

        @using (Html.BeginForm("Create", "Product", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.AntiForgeryToken()
            @Html.HiddenFor(m => m.Id) 

            @Html.ValidationSummary(true, "", new { @class = "text-danger" })

            <div class="mb-3">
                @Html.LabelFor(m => m.Name)
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", id = "Name" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Price)
                @Html.TextBoxFor(m => m.Price, new { @class = "form-control", id = "Price" })
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.Quantity)
                @Html.TextBoxFor(m => m.Quantity, new { @class = "form-control", id = "Quantity" })
            </div>

            <div class="mb-3">
                <label>Ảnh sản phẩm</label>
                <input type="file" name="uploadImage" class="form-control" />
            </div>

            <div class="mb-3">
                @Html.LabelFor(m => m.CategoryId)
                @Html.DropDownListFor(m => m.CategoryId,
                    (SelectList)ViewBag.CategoryList,
                    "-- Chọn danh mục --",
                    new { @class = "form-select", id = "CategoryId" })
            </div>

            <button type="submit" class="btn btn-primary w-100">Lưu sản phẩm</button>
        }

        <hr class="my-5" />

        <h3>Danh sách sản phẩm</h3>

        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Tên</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Ảnh</th>
                    <th>Chức năng</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in ViewBag.Products)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Price</td>
                        <td>@item.Quantity</td>
                        <td>
                            <img src="~/Content/images/@item.Image" width="80" class="img-thumbnail" />
                        </td>

                        <td>
                           
                            <button class="btn btn-warning btn-sm"
                                    onclick="editProduct(@item.Id, '@item.Name.Replace("'", "\\'")', @item.Price, @item.Quantity, @item.CategoryId)">
                                Sửa
                            </button>

                            
                            @using (Html.BeginForm("Delete", "Product", FormMethod.Post))
                            {
                                @Html.Hidden("id", (int)item.Id)
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-danger btn-sm"
                                        onclick="return confirm('Bạn chắc chắn muốn xóa?')">
                                    Xóa
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>