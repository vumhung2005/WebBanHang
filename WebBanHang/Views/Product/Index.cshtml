@model List<WebBanHang.Models.Entity.Product>
<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Danh sách sản phẩm</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        .card:hover {
            transform: scale(1.03);
            transition: 0.3s;
        }

        .card img {
            border-bottom: 1px solid #ddd;
        }
    </style>
</head>
<body>

    <div class="container mt-4">

        <h2 class="mb-4">Danh sách sản phẩm</h2>

        <div class="row mb-4">
            <div class="col-md-3">
                <select class="form-select">
                    <option>Tất cả danh mục</option>
                </select>
            </div>

            <div class="col-md-6">
                <input type="text" class="form-control" placeholder="Tìm kiếm sản phẩm..." />
            </div>

            <div class="col-md-3">
                <button class="btn btn-primary w-100">Tìm kiếm</button>
            </div>
        </div>

        <!-- Button -->
        <div class="mb-3 text-end">
            <a href="/Product/Create" class="btn btn-primary">Thêm sản phẩm</a>
            <button class="btn btn-info">Nạp sản phẩm</button>
            <button class="btn btn-danger">Xóa tất cả</button>
        </div>

        <!-- Product List -->
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4">
                    <a href="/Product/Details/@item.Id">
                        @item.Name
                    </a>
                    <div class="card h-100 shadow-sm">

                        <!-- Image -->
                        <img src="@Url.Content("~/Content/images/" + item.Image)"
                             class="card-img-top"
                             style="height:200px; object-fit:cover;" />

                        <div class="card-body text-center">

                            <!-- Name -->
                            <h5>
                                <a href="/Product/Details/@item.Id" class="text-info text-decoration-none">
                                    @item.Name
                                </a>
                            </h5>

                            <p class="text-muted">Sản phẩm chất lượng cao</p>

                            <!-- Price -->
                            <p class="fw-bold">
                                @String.Format("{0:N0}", item.Price) đ
                            </p>

                            <!-- Button -->
                            <button class="btn btn-primary btn-sm">Đặt hàng</button>

                        </div>
                    </div>
                </div>
            }
        </div>

    </div>

</body>
</html>