@model WebBanHang.ViewModel.RegisterVM

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <h2 style="text-group-align">Register</h2>
    <div>
        @using (Html.BeginForm("Register", "Account", FormMethod.Post))
        {
            <div class="row">
                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.UserName)
                    @Html.TextBoxFor(temp => temp.UserName, new
                    {
                        placeholder =
                        "UserName",
                        @class = "form-control"
                    })
                    @Html.ValidationMessageFor(temp => temp.UserName)
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.Password)
                    @Html.PasswordFor(temp => temp.Password, new
                    {
                        placeholder =
                        "Passord",
                        @class = "form-control"
                    })
                    @Html.ValidationMessageFor(temp => temp.Password)
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.ConfirmPassword)
                    @Html.PasswordFor(temp => temp.ConfirmPassword, new
                    {
                        placeholder =
                        "ConfirmPassword",
                        @class = "form-control"
                    })
                    @Html.ValidationMessageFor(temp => temp.ConfirmPassword)
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.Email)
                    @Html.TextBoxFor(temp => temp.Email, new
                    {
                        placeholder =
                        "Email",
                        @class = "form-control"
                    })
                    @Html.ValidationMessageFor(temp => temp.Email)
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.Addresss)
                    @Html.TextBoxFor(temp => temp.Addresss, new
                    {
                        placeholder =
                        "Address",
                        @class = "form-control"
                    })
                    @Html.ValidationMessageFor(temp => temp.Addresss)
                </div>

                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.DateOfBirth)
                    @Html.TextBoxFor(temp => temp.DateOfBirth, new
                    {
                        placeholder =
                        "DateofBirth",
                        @class = "form-control",
                        type = "date"
                    })
                    @Html.ValidationMessageFor(temp => temp.DateOfBirth)
                </div>
                <div class="col-md-6">
                    @Html.LabelFor(temp => temp.City)
                    @Html.TextBoxFor(temp => temp.City, new
                    {
                        placeholder =
                        "City",
                        @class = "form-control",
                        
                    })
                    @Html.ValidationMessageFor(temp => temp.City)
                </div>

            </div>

            <button type="submit" class="btn btn-success">Register</button>
        }

    </div>
</body>
</html>
